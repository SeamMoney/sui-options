{
  "name": "wick-keeper",
  "version": "0.1.0",
  "description": "Permissionless keeper for Wick Markets — post-C.3 ABI: random-walk ticks, pull-oracle pushes, lock_and_settle, and ride cranking.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "tick": "tsx src/index.ts tick",
    "watch": "tsx src/index.ts watch",
    "setup-key": "tsx src/setup-key.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
