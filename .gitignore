# Dependencies & build outputs
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Committed workspace-lib build artifacts (exception to dist/ above).
# Vercel deploys the frontend with Root Directory = frontend and runs only a
# frontend-scoped install + build, so it never builds the sibling workspace
# libs. Vite then fails to resolve @wick/sdk and the candle-vision / pro-options
# packages (they resolve through their dist/). Committing these dist/ trees makes
# the deploy self-sufficient. Rebuild after changing lib source:
#   npm run build:frontend-deps
!sdk/dist/
!packages/candle-vision/dist/
!packages/candle-vision-react/dist/
!packages/pro-options/dist/

# Env / secrets — never commit these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
.npmrc

# Wick: keeper service key (each operator generates their own)
keeper/.keeper-key.json
*.keeper-key.json

# Vercel CLI artifacts (local link state, env pulled from cloud)
.vercel/

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Move build outputs
move/build/
move/Move.lock

# Python
__pycache__/
*.pyc

# Deployment archive (large rotating files; only deployments/testnet.json is tracked
# alongside the wallet manifest. Each redeploy lands a new file under archive/.)
deployments/archive/

# Local scratch
.claude/
.scratch/
*.local

# robinhood-legend: track source, ignore the heavy build output + captures (~2.9GB)
frontend/robinhood-legend/node_modules/
frontend/robinhood-legend/.next/
frontend/robinhood-legend/public/captures/
frontend/robinhood-legend/public/cdn.robinhood.com/
frontend/robinhood-legend/reference/
.secrets/
.vercel
