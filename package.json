{
  "name": "wick-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Wick Markets — Sui touch/no-touch options. Workspaces: sdk, api, keeper, frontend.",
  "workspaces": [
    "sdk",
    "api",
    "keeper",
    "bots",
    "frontend",
    "packages/candle-vision",
    "packages/candle-vision-react",
    "packages/pro-options"
  ],
  "scripts": {
    "build:candle-vision": "npm -w @sui-options/candle-vision run build",
    "typecheck:candle-vision": "npm -w @sui-options/candle-vision run typecheck",
    "test:candle-vision": "npm -w @sui-options/candle-vision run test",
    "check:candle-vision:browser": "node scripts/candle-vision-browser-check.mjs",
    "check:candle-vision:lightcone": "BROWSER_BACKEND=lightcone CANDLE_VISION_URL=https://wick-markets.vercel.app/candle-vision node scripts/candle-vision-browser-check.mjs",
    "build:candle-vision-react": "npm -w @sui-options/candle-vision-react run build",
    "typecheck:candle-vision-react": "npm -w @sui-options/candle-vision-react run typecheck",
    "release:candle-vision": "node scripts/candle-vision-release-check.mjs && npm run build:candle-vision-react",
    "build:pro-options": "npm -w @sui-options/pro-options run build",
    "typecheck:pro-options": "npm -w @sui-options/pro-options run typecheck",
    "test:pro-options": "npm -w @sui-options/pro-options run test",
    "build:sdk": "npm -w @wick/sdk run build",
    "build:api": "npm -w @wick/api run build",
    "build:frontend": "npm -w frontend run build",
    "build:keeper": "npm -w wick-keeper run build",
    "build:bots": "npm -w wick-bots run build",
    "build": "npm run build:sdk && npm run build:api && npm run build:keeper && npm run build:bots && npm run build:frontend",
    "dev:api": "npm -w @wick/api run dev",
    "dev:frontend": "npm -w frontend run dev",
    "keeper:tick": "npm -w wick-keeper run tick",
    "keeper:watch": "npm -w wick-keeper run watch",
    "bots:setup": "npm -w wick-bots run setup",
    "bots:fund": "npm -w wick-bots run fund",
    "bots:balances": "npm -w wick-bots run balances",
    "bots:run": "npm -w wick-bots run run",
    "bots:tick": "npm -w wick-bots run tick"
  },
  "overrides": {
    "@mysten/sui": "^2.16.0"
  },
  "devDependencies": {
    "@tzafon/lightcone": "^0.14.0"
  }
}
