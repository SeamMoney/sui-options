//@version=1
indicator("Bollinger Bands", overlay=true)
length = input.int(20, "Length")
mult = input.float(2.0, "Multiplier")
basis = ta.sma(close, length)
dev = mult * stdev(close, length)
upper = basis + dev
lower = basis - dev
plot(basis, "Basis", color=#F59E0B)
plot(upper, "Upper", color=#1A56DB)
plot(lower, "Lower", color=#1A56DB)
fill("Upper", "Lower", color=#1A56DB20)
