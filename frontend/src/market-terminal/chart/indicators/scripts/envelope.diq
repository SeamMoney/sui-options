//@version=1
indicator("Envelope", overlay=true)
length = input.int(20, "Length")
pct = input.float(2.5, "Percent")
basis = ta.sma(close, length)
upper = basis * (1 + pct / 100)
lower = basis * (1 - pct / 100)
plot(basis, "Basis", color=#F59E0B)
plot(upper, "Upper", color=#1A56DB)
plot(lower, "Lower", color=#1A56DB)
