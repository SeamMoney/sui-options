# Wick Markets frontend — environment variables
# Copy to `.env.local` and fill in. `.env.local` is gitignored.

# ---------------------------------------------------------------------------
# Dynamic.xyz — social login + embedded Sui wallet
# ---------------------------------------------------------------------------
# Wick defaults to the shared Sui-enabled Dynamic demo snap:
# https://go.dynamic.xyz/4a8HgrV
#
# For a Wick-owned production Dynamic project:
# 1. Sign up at https://app.dynamic.xyz/
# 2. Create a project (or use an existing one).
# 3. Copy the environment id from
#    https://app.dynamic.xyz/dashboard/developer/api
# 4. Paste it below to override the shared demo environment.
# 5. In the Dynamic dashboard, enable the Sui chain at
#    https://app.dynamic.xyz/dashboard/chains-and-networks#sui
#    (without this, SuiWalletConnectors won't render any social options).
# 6. Add this app's dev origin (http://localhost:5173) and your Vercel
#    preview/prod origins to "CORS origins" in the Dynamic dashboard.
VITE_DYNAMIC_ENVIRONMENT_ID=

# ---------------------------------------------------------------------------
# Enoki (sponsored gas) — OPTIONAL, NOT YET WIRED
# ---------------------------------------------------------------------------
# Dynamic does NOT bundle Enoki natively (verified May 2026 — their
# "gasless transactions" guide describes a custom server-side sponsor wallet,
# not Enoki). To sponsor `open_ride` / `close_ride` so users don't need SUI
# in their wallet, you must:
#   1. Sign up at https://enoki.mystenlabs.com/
#   2. Generate a public Enoki key for testnet.
#   3. Paste it below and wire it through `EnokiClient` in
#      `frontend/src/lib/sui.ts` (TODO — not done in the initial Dynamic
#      integration pass; the Dynamic-backed wallet still signs PTBs that
#      consume the user's own SUI for gas).
#   4. Allowlist the Wick package id (read it from
#      `deployments/testnet.json#package_id`) in the Enoki dashboard.
VITE_ENOKI_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Faucet button — calls /api/faucet (the Vercel serverless function in
# `api/faucet.ts`) to drip 0.05 testnet SUI to the connected wallet.
# ---------------------------------------------------------------------------
# Auto-set on Vercel deploys; localhost dev usually doesn't need this
VITE_FAUCET_ENABLED=true
