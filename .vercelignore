# Vercel-side ignore rules.
#
# Without this, Vercel would try to bundle every .ts file under api/ as a
# separate serverless function. We only want the real endpoints (faucet.ts,
# faucet-tusd.ts, sponsor.ts). The api/src/ tree is the @wick/api Fastify
# workspace, which is deployed elsewhere (Fly / Railway / self-hosted) and uses
# top-level await + Fastify in a way that breaks Vercel's Node bundler.

api/src/
api/smoke.ts
api/README.md
# Test files must never be bundled as serverless functions — they import a test
# runner and export no handler. They now live OUTSIDE api/ (in api-tests/, so
# Vercel's api/ functions glob can never pick them up), but we belt-and-braces
# exclude every test file regardless of location.
api-tests/
api/**/*.test.ts
**/*.test.ts

# Non-frontend workspaces are not needed inside the Vercel build sandbox.
# Note: sdk/ must NOT be excluded — the frontend imports @wick/sdk via
# `file:../sdk`, and the Vercel build pipeline (`npm run build:sdk &&
# npm -w frontend run build`) compiles sdk/src first.
move/
keeper/
bots/
scripts/
docs/
research/
deployments/archive/

# Local scratch / secrets — already gitignored, double-fence here so they
# can't be uploaded even if someone runs `vercel deploy` from a dirty tree.
.secrets/
.scratch/
.claude/
*.local
*.key
